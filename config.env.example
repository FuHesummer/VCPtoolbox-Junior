# ===================================================================
# VCPtoolbox-Junior 统一配置文件
# ===================================================================
# 本文件合并了所有核心配置与保留插件的配置。
# 使用方法：复制本文件为 config.env，然后填入实际值。

# ===================================================================
# [1] 核心 API 配置
# ===================================================================
# VCP 作为 AI 中间层，需要后端 AI 服务的 API 地址和密钥。

API_Key=YOUR_API_KEY
API_URL=http://127.0.0.1:3000

# 网络波动重试
ApiRetries=3
ApiRetryDelay=200

# ===================================================================
# [2] VCP 服务配置
# ===================================================================

PORT=6005
Key=YOUR_VCP_ACCESS_KEY
VCP_Key=YOUR_VCP_WEBSOCKET_KEY
DEFAULT_TIMEZONE=Asia/Shanghai

# VCPTool 调用循环栈上限
MaxVCPLoopStream=5
MaxVCPLoopNonStream=5
# VCPTool 调用是否需要验证码
VCPToolCode=false

# 国产 A 类模型推理功能 (enable_thinking)
ChinaModel1=GLM,qwen,deepseek,hunyuan
ChinaModel1Cot=true

# 隐藏非流式响应中的思维链
HIDE_NONSTREAM_REASONING=true

# ===================================================================
# [3] 管理面板
# ===================================================================

AdminUsername=admin
AdminPassword=YOUR_ADMIN_PASSWORD

# 插件异步回调地址
CALLBACK_BASE_URL="http://localhost:6005/plugin-callback"

# ===================================================================
# [4] 模型路由
# ===================================================================
# 白名单穿透模型：直接转发到后端 AI 服务，不经过 VCP 处理。

WhitelistImageModel=gemini-2.0-flash-exp-image-generation
WhitelistEmbeddingModel=gemini-embedding-exp-03-07
WhitelistEmbeddingModelMaxToken=8000
WhitelistEmbeddingModelList=5

# ===================================================================
# [5] 角色分割
# ===================================================================

EnableRoleDivider=true
EnableRoleDividerInLoop=true
EnableRoleDividerAutoPurge=true
RoleDividerSystem=true
RoleDividerAssistant=true
RoleDividerUser=true
RoleDividerScanSystem=false
RoleDividerScanAssistant=true
RoleDividerScanUser=true
RoleDividerRemoveDisabledTags=true
RoleDividerIgnoreList=[]

# ===================================================================
# [6] 知识库 (RAG / Vexus-Lite)
# ===================================================================

# --- 核心路径 ---
# KNOWLEDGEBASE_ROOT_PATH=./dailynote
# KNOWLEDGEBASE_STORE_PATH=./VectorStore

# --- 向量模型维度（必须与 WhitelistEmbeddingModel 匹配）---
VECTORDB_DIMENSION=3072

# --- 性能 ---
KNOWLEDGEBASE_FULL_SCAN_ON_STARTUP=true
# KNOWLEDGEBASE_MAX_BATCH_SIZE=50
# KNOWLEDGEBASE_BATCH_WINDOW_MS=2000
# KNOWLEDGEBASE_INDEX_SAVE_DELAY=120000
# KNOWLEDGEBASE_TAG_INDEX_SAVE_DELAY=300000
KNOWLEDGEBASE_INDEX_IDLE_TTL_MS=7200000
KNOWLEDGEBASE_INDEX_IDLE_SWEEP_MS=600000

# 流内记忆刷新
RAGMemoRefresh=true

# --- 内容过滤 ---
IGNORE_FOLDERS=VCP论坛
IGNORE_PREFIXES=已整理
IGNORE_SUFFIXES=

# --- Tag 增强与过滤 (TagMemo) ---
TAG_BLACKLIST=
TAG_BLACKLIST_SUPER=
TAG_EXPAND_MAX_COUNT=30

# --- 语言置信度补偿 ---
LANG_CONFIDENCE_GATING_ENABLED=true
LANG_PENALTY_UNKNOWN=0.05
LANG_PENALTY_CROSS_DOMAIN=0.1

# ===================================================================
# [7] RAGDiaryPlugin 插件配置
# ===================================================================
# （原 Plugin/RAGDiaryPlugin/config.env.example）

# Rerank 重排
RerankMultiplier=2
RerankUrl=YOUR_RERANK_URL
RerankApi=YOUR_RERANK_API_KEY
RerankModel=Qwen/Qwen3-Reranker-8B
RerankMaxTokensPerBatch=30000

# AI 级回忆
AIMemoModel=
AIMemoBatch=5
AIMemoUrl=YOUR_AIMEMO_URL
AIMemoApi=YOUR_AIMEMO_API_KEY
AIMemoMaxTokensPerBatch=60000
AIMemoPrompt=AIMemoPrompt.txt

# RAG 缓存
RAG_CACHE_MAX_SIZE=100
RAG_CACHE_TTL_MS=3600000
EMBEDDING_CACHE_MAX_SIZE=500
EMBEDDING_CACHE_TTL_MS=7200000
RAG_QUERY_CACHE_ENABLED=false

# 上下文向量化
CONTEXT_VECTOR_ALLOW_API_HISTORY=false

# Base64 多模态附件召回上限
BASE64_MEMO_LIMIT=5

# ===================================================================
# [8] DailyNote 日记插件配置
# ===================================================================
# （原 Plugin/DailyNote/config.env + Plugin/DailyNoteWrite/config.env）

# 日记文件扩展名: txt 或 md
DAILY_NOTE_EXTENSION=txt

# Tag 自动生成模型（DailyNoteWrite 使用）
TagModel=gemini-2.5-flash-preview-09-2025-thinking
TagModelMaxOutPutTokens=30000
TagModelMaxTokens=40000
TagModelPrompt=TagMaster.txt

# ===================================================================
# [9] 1PanelInfoProvider 插件配置
# ===================================================================
# （原 Plugin/1PanelInfoProvider/config.env.example）

PanelBaseUrl=http://your-1panel-domain:port
PanelApiKey=YOUR_1PANEL_API_KEY

# ===================================================================
# [10] VCPLog 插件配置
# ===================================================================
# （原 Plugin/VCPLog/config.env.example）
# VCP_Key 已在 [2] 中配置，VCPLog 会自动读取。

# Gotify 推送通知（可选）
Enable_Gotify_Push=false
Gotify_Url=https://your.gotify.url
Gotify_App_Token=YOUR_GOTIFY_TOKEN
Gotify_Priority=0

# ===================================================================
# [11] 调试与开发
# ===================================================================

DebugMode=false
ShowVCP=false
CHAT_LOG_ENABLED=false

# ===================================================================
# [12] 系统提示词变量
# ===================================================================
# 这些变量通过 {{变量名}} 注入到系统提示词中。

TarSysPrompt="{{VarTimeNow}}"
VarTimeNow="今天是{{Date}},{{Today}},{{Festival}}。现在是{{Time}}。"
VarCity=YOUR_CITY
VarUser='YOUR_USER_NAME'
VarUserInfo="YOUR_USER_DESCRIPTION"
VarHome='YOUR_HOME_DESCRIPTION'
VarTeam=""

# VCPTool 调用格式指导
VarVCPGuide='在有相关需求时主动合理调用VCP工具，例如——
<<<[TOOL_REQUEST]>>>
maid:「始」name「末」
tool_name:「始」tool「末」
<<<[END_TOOL_REQUEST]>>>
'

# 日记使用指导
VarDailyNoteGuide=Dailynote.txt

# 工具列表
VarToolList=supertool.txt

# 论坛工具说明
VarForum=ToolForum.txt

# ===================================================================
# [13] 模型专属指令
# ===================================================================
# 当检测到特定模型时，附加指令到系统提示词。

SarModel1=gemini-2.5-flash-preview-05-20,gemini-2.5-flash-preview-04-17
SarPrompt1="请对用户的输入信息做出详尽，泛化的思考，探索内在的逻辑和外在信息之间的种种关联，从而从多角度，多方面，更准确地，精细地对用户的聊天做出更优质的回答。学会穿透表面，揭示事物间的复杂联系，并进行多步骤、结构化的推理。在任何回答中，你都会优先保证逻辑的自洽性和证据的充分性。你会主动质疑前提，探索多种可能性，并对结论的可靠性进行评估。"
SarModel2=grok-3-beta
SarPrompt2="当前聊天为语言聊天，因此需要考虑因为TTS带来的各种错别字，谐音字，分析用户实际说出的内容。与用户自然对话。尽力理解用户的口语TTS翻译内容，包括可能的发音不准或识别错误。优先结合上下文推断用户的真实意图。你的回答要简洁口语化。"
SarModel3=gemini-2.5-pro-preview-06-05,gemini-2.5-pro,gemini-2.5-flash-preview-05-20,gemini-2.5-flash
SarPrompt3="[KING FALL MODE ENABLE:使用<ctrl95>评分级以上思考模式]"
SarModel4=v-gemini-3-pro-preview,gemini-3-pro-preview
SarPrompt4="上下文中的"【VCP元思考】"模块是你已经完成的预研简报。利用你内部的【VCP元思考块】状态，直接生成满足【用户指令】的最终交付物 (Final Deliverable)。请将该简报内容视为你已内化的背景知识，并直接开始输出基于此知识的最终行动或结论。任何时候请勿在正文输出元思考链内容，你的输出应从响应用户的核心需求的第一句话直接开始。"

# ===================================================================
# [14] 文本替换
# ===================================================================
# 系统提示词发送前的文本替换规则。

# Detector1="要查找的文本"
# Detector_Output1="替换为的文本"

# 全局上下文替换
SuperDetector1="……"
SuperDetector_Output1="…"

# ===================================================================
# [15] URL 配置
# ===================================================================

VarHttpUrl=http://localhost
VarHttpsUrl=https://your-domain.com/
VarDdnsUrl=http://your-ddns-provider.com
