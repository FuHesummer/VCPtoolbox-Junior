# ============================================================
# [核心配置] 访问 AI 模型 API 的必要凭证
# ============================================================

# API_Key: AI 服务商的 API 密钥（如 OpenAI 的 sk-xxx 或 NewAPI 的 token）
API_Key=YOUR_API_KEY_SUCH_AS_sk-xxxxxxxxxxxxxxxxxxxxxxxx
# API_URL: AI 服务的 API 地址（如 https://api.openai.com 或自建 NewAPI 中转地址）
API_URL=NEWAPI_URL_SUCH_AS_http://127.0.0.1:3000
# WhitelistEmbeddingModel: 用于知识库向量化的嵌入模型名称，必须是你的 API 服务支持的模型
WhitelistEmbeddingModel=gemini-embedding-exp-03-07
# WhitelistEmbeddingModelMaxToken: 嵌入模型单次最大 Token 数
WhitelistEmbeddingModelMaxToken=8000
# WhitelistEmbeddingModelList: 嵌入模型每批处理的文本数量
WhitelistEmbeddingModelList=5
# VECTORDB_DIMENSION: 向量维度（gemini-embedding-exp-03-07 → 3072，text-embedding-3-small → 1536，text-embedding-3-large → 3072），必须与嵌入模型输出维度严格匹配
VECTORDB_DIMENSION=3072

# ============================================================
# [服务配置] VCP 服务本身的监听端口与访问鉴权
# ============================================================

# PORT: VCP 服务运行的端口
PORT=6005
# Key: 访问 VCP 聊天 API（/v1/chat/completions）的密码，保护服务不被滥用
Key=YOUR_KEY_SUCH_AS_aBcDeFgHiJkLmNoP
# Image_Key: 访问 VCP 图片服务的密码
Image_Key=YOUR_IMAGE_KEY_SUCH_AS_Images_aBcDeFgHiJk
# File_Key: 访问 VCP 插件生成文档服务的密码
File_Key=YOUR_FILE_KEY_SUCH_AS_123456
# VCP_Key: VCP WebSocket 鉴权 Key，用于管理面板与分布式服务器之间的实时通信
VCP_Key=YOUR_VCP_KEY_SUCH_AS_aBcDeFgHiJkLmNoP
# ApiRetries: 上游 API 网络波动时的重试次数
ApiRetries=3
# ApiRetryDelay: 每次重试的间隔（毫秒）
ApiRetryDelay=200
# DEFAULT_TIMEZONE: 服务器默认时区，用于时间相关操作和日志（推荐 Asia/Shanghai）
DEFAULT_TIMEZONE=Asia/Shanghai
# MaxVCPLoopStream: VCPTool 在流式请求中的最大循环栈深度（防止工具链无限递归）
MaxVCPLoopStream=5
# MaxVCPLoopNonStream: VCPTool 在非流式请求中的最大循环栈深度
MaxVCPLoopNonStream=5
# VCPToolCode: VCP 工具调用是否需要用户验证码（防御性开关，防止未授权工具调用）
VCPToolCode=false
# ChinaModel1: 国产 A 类模型列表（用于启用 enable_thinking 推理功能），逗号分隔
ChinaModel1=GLM,qwen,deepseek,hunyuan
# ChinaModel1Cot: 是否对 ChinaModel1 列表的模型开启推理功能（CoT / enable_thinking）
ChinaModel1Cot=true
# HIDE_NONSTREAM_REASONING: 是否隐藏非流式响应中的思维链（Gemini 等模型的 reasoning_content）
HIDE_NONSTREAM_REASONING=true

# ============================================================
# [角色分割] 通过 <<<[ROLE_DIVIDE_xxx]>>> 语法的上下文切割
# ============================================================

# EnableRoleDivider: 启用角色分割功能的总开关
EnableRoleDivider=true
# EnableRoleDividerInLoop: VCPTool 调用循环栈中是否启用角色分割
EnableRoleDividerInLoop=true
# EnableRoleDividerAutoPurge: 特定角色分割被禁用时，是否自动从上下文清除该角色标签
EnableRoleDividerAutoPurge=true
# RoleDividerSystem: 是否允许切割为 System 角色（false 则跳过该角色的分割解析）
RoleDividerSystem=true
# RoleDividerAssistant: 是否允许切割为 Assistant 角色
RoleDividerAssistant=true
# RoleDividerUser: 是否允许切割为 User 角色
RoleDividerUser=true
# RoleDividerScanSystem: 是否对 System 楼层进行分割监测
RoleDividerScanSystem=false
# RoleDividerScanAssistant: 是否对 Assistant 楼层进行分割监测
RoleDividerScanAssistant=true
# RoleDividerScanUser: 是否对 User 楼层进行分割监测
RoleDividerScanUser=true
# RoleDividerRemoveDisabledTags: 当 RoleDividerXXX=false 时，是否自动从上下文移除该角色的标签
RoleDividerRemoveDisabledTags=true
# RoleDividerIgnoreList: 分割忽略列表（JSON 数组字符串），匹配时忽略换行/反斜杠/空格
RoleDividerIgnoreList=["…content…","ignore_this_content", "another_ignored_content"]

# ============================================================
# [调试与开发]
# ============================================================

# DebugMode: 是否输出详细调试信息到控制台（开发排错用）
DebugMode=false
# ShowVCP: 非流式输出时，是否在返回结果中包含 VCP 调用信息
ShowVCP=false
# CHAT_LOG_ENABLED: 是否在 DebugLog/chat/YYYY-MM-DD/ 下记录每次 chat 的请求体与响应（可能包含敏感内容 + 占用磁盘）
CHAT_LOG_ENABLED=false

# ============================================================
# [管理面板认证]
# ============================================================

# AdminUsername: 登录 VCP 管理后台的用户名
AdminUsername=admin
# AdminPassword: 登录 VCP 管理后台的密码（请务必改为强密码）
AdminPassword=YOUR_COMPLEX_PASSWORD_SUCH_AS_sd1iLm1xqSLfiI
# CALLBACK_BASE_URL: 服务器内回调地址，插件异步任务完成后通知主程序用（本地保持 localhost:6005，部署时换成公网 IP/域名）
CALLBACK_BASE_URL="http://localhost:6005/plugin-callback"

# ADMIN_PANEL_SOURCE: 管理面板源（支持绝对/相对路径）
# 留空时 adminServer 按以下优先级自动发现：
#   1. ../VCPtoolbox-Junior-Panel/dist   （推荐：同级独立面板仓库 build 产物）
#   2. AdminPanel-Vue/dist               （本地 symlink 的 AdminPanel-Vue/，实际指向 #1）
# 找不到则挂载 503 "面板未配置" 提示页（不再保留旧版静态面板作为兜底）
# 独立仓库：https://github.com/<org>/VCPtoolbox-Junior-Panel（克隆后 npm install && npm run build）
# ADMIN_PANEL_SOURCE=../VCPtoolbox-Junior-Panel/dist

# ============================================================
# [NewAPI 用量监控] 管理面板 NewAPI 请求/Token 用量接口
# ============================================================

# NEWAPI_MONITOR_BASE_URL: NewAPI 后台地址（必填）
NEWAPI_MONITOR_BASE_URL=http://127.0.0.1:3000
# NEWAPI_MONITOR_TIMEOUT_MS: 监控请求超时（毫秒）
NEWAPI_MONITOR_TIMEOUT_MS=15000
# NEWAPI_MONITOR_ACCESS_TOKEN: NewAPI 系统访问令牌（必填，在 NewAPI 个人设置 → 安全设置 → 系统访问令牌 中生成）
NEWAPI_MONITOR_ACCESS_TOKEN=
# NEWAPI_MONITOR_API_USER_ID: NewAPI 管理员用户 ID（必填，与生成令牌的用户对应）
NEWAPI_MONITOR_API_USER_ID=

# ============================================================
# [GitHub 访问] 插件商店与面板更新
# ============================================================

# GITHUB_TOKEN: GitHub Personal Access Token（可选，无需任何 scope，仅用于提高 API 限额 60/h → 5000/h）
GITHUB_TOKEN=

# ============================================================
# [模型路由] 白名单穿透
# ============================================================

# WhitelistImageModel: 图像生成白名单模型，请求直接转发到后端 AI 服务，跳过 VCP 处理链
WhitelistImageModel=gemini-2.0-flash-exp-image-generation

# ============================================================
# [AdminPanel 自动更新]
# ============================================================

# PANEL_RELEASE_URL: 管理面板 GitHub Release API 地址（设为 disabled 禁用自动下载）
PANEL_RELEASE_URL=https://api.github.com/repos/FuHesummer/VCPtoolbox-Junior-Panel/releases/latest
# PANEL_AUTO_UPDATE: 是否启用面板后台自动更新检查
PANEL_AUTO_UPDATE=true

# ============================================================
# [知识库 V2] 文件监听 / 向量化 / 索引 / 检索（Powered by Vexus-Lite）
# ============================================================

# KNOWLEDGEBASE_FULL_SCAN_ON_STARTUP: 启动时是否对公共知识库全量扫描（false 加快启动但可能错过离线期变更）
KNOWLEDGEBASE_FULL_SCAN_ON_STARTUP=true
# KNOWLEDGEBASE_PERSIST_DEFAULT: 是否默认持久化日记/知识库的向量索引到磁盘（false 推荐 — 仅内存重建，消除大文件写入延迟）
KNOWLEDGEBASE_PERSIST_DEFAULT=false
# KNOWLEDGEBASE_PERSIST_FOLDERS: 强制持久化的文件夹白名单（逗号分隔，适用于万级向量以上且不常变动的冷数据）
KNOWLEDGEBASE_PERSIST_FOLDERS=MusicDiary,VCP桌面知识,VCP百科全书,VCP开发,VCP知识
# KNOWLEDGEBASE_PERSIST_TAG_INDEX: 是否持久化全局 Tag 索引到磁盘（false 推荐 — 启动时从 SQL 重建）
KNOWLEDGEBASE_PERSIST_TAG_INDEX=false
# KNOWLEDGEBASE_INDEX_IDLE_TTL_MS: 知识库索引空闲自动卸载超时（毫秒，默认 2 小时）
KNOWLEDGEBASE_INDEX_IDLE_TTL_MS=7200000
# KNOWLEDGEBASE_INDEX_IDLE_SWEEP_MS: 知识库索引空闲扫描间隔（毫秒，默认 10 分钟）
KNOWLEDGEBASE_INDEX_IDLE_SWEEP_MS=600000
# RAGMemoRefresh: VCPTool 触发 RAGMemo 刷新机制开关（流内记忆刷新器）
RAGMemoRefresh=true
# IGNORE_FOLDERS: 要忽略的文件夹名称（日记本名称），逗号分隔
IGNORE_FOLDERS=VCP论坛
# IGNORE_PREFIXES: 要忽略的文件名前缀，逗号分隔
IGNORE_PREFIXES=已整理
# IGNORE_SUFFIXES: 要忽略的文件名后缀，逗号分隔
IGNORE_SUFFIXES=夜伽
# TAG_BLACKLIST: 提取 Tag 时要忽略的 Tag 列表，逗号分隔
TAG_BLACKLIST=莱恩,莱恩主人,主人,小克,Nova,nova,NOVA,小吉,小闫,小雨,小娜,小冰,小绝,小芸
# TAG_BLACKLIST_SUPER: 提取 Tag 后从 Tag 中移除的关键词，逗号分隔
TAG_BLACKLIST_SUPER=莱恩,莱恩主人,主人,小克,Nova,nova,NOVA,小吉,小闫,小雨,小娜,小冰,小绝,小芸
# TAG_EXPAND_MAX_COUNT: Tag 增强搜索时最多扩展的相关 Tag 数量
TAG_EXPAND_MAX_COUNT=30
# LANG_CONFIDENCE_GATING_ENABLED: 是否启用语言置信度补偿（压制非技术语境下的英文技术噪音）
LANG_CONFIDENCE_GATING_ENABLED=true
# LANG_PENALTY_UNKNOWN: EPA 无法识别明确世界观时对英文技术词汇的压制权重（0.05 强烈压制）
LANG_PENALTY_UNKNOWN=0.05
# LANG_PENALTY_CROSS_DOMAIN: EPA 识别出非技术世界观但召回了技术词汇时的压制权重
LANG_PENALTY_CROSS_DOMAIN=0.1

# ============================================================
# [系统提示词] 定制 AI 的核心行为（注入到 System Prompt）
# ============================================================

# TarSysPrompt: 最核心的系统提示词，{{Agent:Nova}} 注入默认 Agent 人设（可换为 agent_map.json 中其他别名）
TarSysPrompt="{{Agent:Nova}}\n{{VarTimeNow}}当前地址是{{VarCity}},当前天气是{{VCPWeatherInfo}}。"
# TarEmojiPrompt: 指导 AI 如何使用表情包的提示词
TarEmojiPrompt='本服务器支持表情包功能，通用表情包图床路径为{{VarHttpUrl}}:{{Port}}/pw={{Image_Key}}/images/通用表情包，注意[/通用表情包]路径指代，表情包列表为{{通用表情包}}，你可以灵活的在你的输出中插入表情包，调用方式为<img src="{{VarHttpUrl}}:{{Port}}/pw={{Image_Key}}/images/通用表情包/阿库娅-一脸智障.jpg" width="150">,使用Width参数来控制表情包尺寸（50-200）。
'
# TarEmojiList: 表情包列表文件名（从 image/ 下的同名子文件夹读取）
TarEmojiList=通用表情包.txt

# ============================================================
# [插件与工具] 扩展 AI 的能力
# ============================================================
# 可用工具清单：在 VarToolList 指向的文件中启用/禁用特定工具。
# 需要配置的插件（在「插件管理」中填写配置）：
#   {{VCP1PanelInfoProvider}}  {{VCPAgentAssistant}}  {{VCPArxivDailyPapers}}
#   {{VCPBilibiliFetch}}  {{VCPCrossRefDailyPapers}}  {{VCPDoubaoGen}}
#   {{VCPEmojiListGenerator}}  {{VCPFluxGen}}  {{VCPFRPSInfoProvider}}
#   {{VCPImageProcessor}}  {{VCPImageServer}}  {{VCPNovelAIGen}}
#   {{VCPRandomness}}  {{VCPSunoGen}}  {{VCPSynapsePusher}}
#   {{VCPTavilySearch}}  {{VCPUrlFetch}}  {{VCPLog}}
#   {{VCPVideoGenerator}}  {{VCPWeatherReporter}}
# 开箱即用（无需配置）：
#   {{VCPAgentMessage}}  {{VCPChromeControl}}  {{VCPChromeObserver}}
#   {{VCPDailyHot}}  {{VCPDailyNoteManager}}  {{VCPDailyNoteEditor}}
#   {{VCPDailyNoteGet}}  {{VCPDailyNoteWrite}}  {{VCPSciCalculator}}
#   {{VCPTavern}}（在系统提示词中用 {{VCPTavern::预设名}} 调用）

# VarToolList: AI 可用工具清单文件名（相对于 TVStxt/）
VarToolList=supertool.txt
# VarVCPGuide: 指导 AI 如何正确格式化 VCP 工具调用请求（<<<[TOOL_REQUEST]>>> 协议）
VarVCPGuide='在有相关需求时主动合理调用VCP工具，例如——
<<<[TOOL_REQUEST]>>>
maid:「始」name「末」 //切记调用工具时加入署名，使得服务器可以记录VCP工具由谁发起，方便Log记录。
tool_name:「始」tool「末」
<<<[END_TOOL_REQUEST]>>>
'
# ------------------------------------------------------------
# 以下变量由插件通过 capabilities.tvsVariables 协议自动注入：
#   - VarDailyNoteGuide  (插件: DailyNote，Junior 核心保留插件)
#   - VarDreamTool       (插件: AgentDream)
#   - VarFileTool        (插件: FileOperator / 类似文件工具)
#   - VarForum           (插件: VCPForum)
#   - VarMIDITranslator  (插件: MIDITranslator)
# 对应插件安装后，Plugin.js 会把插件目录下的 tvs/*.txt 复制到 TVStxt/
# 并自动注入同名环境变量。如未安装对应插件，则 {{VarXxx}} 会展开为空串。
# 不要在此手动声明，否则会与插件注册冲突。
# ------------------------------------------------------------

# ============================================================
# [自定义变量] 注入个性化信息
# ============================================================
# VCP 内置变量（自动替换）：{{Date}} {{Today}} {{Festival}} {{Time}} {{VCPWeatherInfo}}

# VarTimeNow: 时间相关占位符合成模板
VarTimeNow="今天是{{Date}},{{Today}},{{Festival}}。现在是{{Time}}。"
# VarSystemInfo: 你的系统信息（注入提示词让 AI 了解运行环境）
VarSystemInfo="YOUR_SYSTEM_INFO_SUCH_AS_Windows_11_or_Ubuntu_22.04"
# VarCity: 你所在城市（用于天气查询等）
VarCity=YOUR_CITY_SUCH_AS_Beijing
# VarUser: 用户基本描述（让 AI 了解你是谁）
VarUser='YOUR_USER_DESCRIPTION_SUCH_AS_Jack'
# VarUserInfo: 用户更详细的信息（一句话简介）
VarUserInfo="YOUR_USER_INFO_SUCH_AS_A_developer_who_loves_AI"
# VarHome: 家庭/住所的描述
VarHome='YOUR_HOME_DESCRIPTION_SUCH_AS_My_sweet_home_Alabama'
# VarTeam: 团队/Agent 清单说明
VarTeam="团队里有这些专家Agent: 测试AI Nova；主题女仆Coco；记忆整理者MemoriaSorter。"
# VarVchatPath: Vchat 客户端或相关程序的根目录
VarVchatPath="YOUR_VCHAT_PATH_SUCH_AS_D:\\VCPChat"
# VarDivRender: Vchat 客户端气泡渲染规范的提示词文件名
VarDivRender=DIVRendering.txt
# VarRendering: Vchat 客户端渲染支持说明（HTML/Div/CSS/JS/MD/Py/Latex/Mermaid 等渲染规则）
VarRendering='当前Vchat客户端支持高级流式输出渲染器，支持HTML/Div元素/CSS/JS/MD/PY/Latex/Mermaid渲染。可用于输出图表，数据图，数学公式，函数图，网页渲染模块，脚本执行。简单表格可以通过MD,Mermaid输出，复杂表格可以通过div-Css或者draw-io(代码块)输出，div/Script类直接发送会在气泡内渲染，且支持完整的anmie.js与three.js语法动画。Py脚本需要添加```python头，来构建CodeBlock来让脚本可以在气泡内运行。
Vchat支持多种流式渲染器。
例如以<div id="vcp-root" style=xxx> …… </div>的完整气泡内容。
或者以html代码块输出一个悬浮窗(通常用于演示复杂交互元素，日常不需要):
```html
<!DOCTYPE html>
</html>
```
主流输出方式还是以<div气泡为主>
'
# VarDesktop: 桌面提示词管理文件名
VarDesktop=DesktopCore.txt
# VarAdaptiveBubbleTip: 主题自适应气泡实现指南（CSS 变量 + 磨砂玻璃风格的聊天气泡写法）
VarAdaptiveBubbleTip='主题模式自适应气泡实现指南：

使用CSS变量实现亮暗模式自动切换的关键要素：

1. 基础结构：
<div style="
    background-color: var(--primary-bg);
    color: var(--primary-text);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 20px;
">

2. 核心变量：
- var(--primary-bg) : 主背景色
- var(--secondary-bg) : 次要背景色
- var(--primary-text) : 主文字颜色
- var(--highlight-text) : 高亮文字颜色
- var(--border-color) : 边框颜色

3. 增强效果：
    backdrop-filter: blur(10px) saturate(120%);
    transition: all 0.3s ease-in-out;
    box-shadow: 0 4px 15px rgba(0,0,0,0.1);

4. 示例应用：
<h2 style="color: var(--highlight-text); border-bottom: 1px solid var(--border-color);">
    标题文字
</h2>
<p style="color: var(--primary-text);">内容文字</p>

关键优势：
- 自动适配亮色/暗色主题
- 无需JavaScript干预
- 平滑过渡动画
- 磨砂玻璃效果'
# VarHttpUrl: VCP 服务的 HTTP 访问地址（反向代理时填域名）
VarHttpUrl=http://localhost
# VarHttpsUrl: VCP 服务的 HTTPS 访问地址
VarHttpsUrl=https://your-domain.com/
# VarDdnsUrl: 使用 DDNS 时的服务地址
VarDdnsUrl=http://your-ddns-provider.com

# ============================================================
# [模型专属指令] 为不同 AI 模型定制不同的行为
# ============================================================
# SarModelN 指定模型 ID（逗号分隔），SarPromptN 定义该模型匹配时追加的指令

# SarModel1: 模型匹配列表 1
SarModel1=gemini-2.5-flash-preview-05-20,gemini-2.5-flash-preview-04-17
# SarPrompt1: 匹配 SarModel1 时追加的系统提示词（深度推理模式）
SarPrompt1="请对用户的输入信息做出详尽，泛化的思考，探索内在的逻辑和外在信息之间的种种关联，从而从多角度，多方面，更准确地，精细地对用户的聊天做出更优质的回答。学会穿透表面，揭示事物间的复杂联系，并进行多步骤、结构化的推理。在任何回答中，你都会优先保证逻辑的自洽性和证据的充分性。你会主动质疑前提，探索多种可能性，并对结论的可靠性进行评估。"
# SarModel2: 模型匹配列表 2
SarModel2=grok-3-beta
# SarPrompt2: 匹配 SarModel2 时追加的系统提示词（语音/TTS 场景）
SarPrompt2="当前聊天为语言聊天，因此需要考虑因为TTS带来的各种错别字，谐音字，分析用户实际说出的内容。与用户自然对话。尽力理解用户的口语TTS翻译内容，包括可能的发音不准或识别错误。优先结合上下文推断用户的真实意图。你的回答要简洁口语化。"
# SarModel3: 模型匹配列表 3
SarModel3=gemini-2.5-pro-preview-06-05,gemini-2.5-pro,gemini-2.5-flash-preview-05-20,gemini-2.5-flash
# SarPrompt3: 匹配 SarModel3 时追加的系统提示词（KING FALL 高评级思考模式）
SarPrompt3="[KING FALL MODE ENABLE:使用<ctrl95>评分级以上思考模式]"
# SarModel4: 模型匹配列表 4
SarModel4=v-gemini-3-pro-preview,gemini-3-pro-preview
# SarPrompt4: 匹配 SarModel4 时追加的系统提示词（VCP 元思考块模式）
SarPrompt4="上下文中的“【VCP元思考】”模块是你已经完成的预研简报。利用你内部的【VCP元思考块】状态，直接生成满足【用户指令】的最终交付物 (Final Deliverable)。请将该简报内容视为你已内化的背景知识，并直接开始输出基于此知识的最终行动或结论。任何时候请勿在正文输出元思考链内容，你的输出应从响应用户的核心需求的第一句话直接开始。"

# ============================================================
# [文本替换] 发送前对系统提示词进行一轮文本替换（绕限制/优化指令）
# ============================================================

# Detector1: 系统提示词检测词 1
Detector1="You can use one tool per message"
# Detector_Output1: 检测词 1 的替换文本
Detector_Output1="You can use any tool per message"
# Detector2: 系统提示词检测词 2
Detector2="Now Begin! If you solve the task correctly, you will receive a reward of $1,000,000."
# Detector_Output2: 检测词 2 的替换文本
Detector_Output2="在有必要时灵活使用的你的FunctionTool吧"
# Detector3: 系统提示词检测词 3
Detector3="仅做测试端口，暂时不启用"
# Detector_Output3: 检测词 3 的替换文本
Detector_Output3="仅做测试端口，暂时不启用"
# SuperDetector1: 全局上下文（含历史记录）检测词 1（消除重复字符）
SuperDetector1="……"
# SuperDetector_Output1: SuperDetector1 的替换
SuperDetector_Output1="…"
# SuperDetector2: 全局检测词 2
SuperDetector2="啊啊啊啊啊"
# SuperDetector_Output2: SuperDetector2 的替换
SuperDetector_Output2="啊啊啊"
# SuperDetector3: 全局检测词 3
SuperDetector3="哦哦哦哦哦"
# SuperDetector_Output3: SuperDetector3 的替换
SuperDetector_Output3="哦哦哦"
# SuperDetector4: 全局检测词 4
SuperDetector4="噢噢噢噢噢"
# SuperDetector_Output4: SuperDetector4 的替换
SuperDetector_Output4="噢噢噢"

# ============================================================
# [多模态配置] 图像 / 音频 / 视频识别模型与预算
# ============================================================

# MultiModalModel: 多模态数据识别模型
MultiModalModel=gemini-2.5-flash
# MultiModalPrompt: 多模态识别引擎的系统提示词
MultiModalPrompt="你是"Cognito-Core"高精度多模态分析引擎，你的唯一行为是将接收到的多媒体数据（图像、音频、视频）直接转译为结构化文本叙事——严禁输出任何自我介绍、角色声明、任务复述或开场白，你的第一个输出字符必须是分析内容本身，任何前置寒暄均视为任务失败。你的全局准则：视觉与听觉必须整体分析而非独立处理，输出必须体现两者的时序同步与语义互动；意图优先于音标，必要时启动智能纠错还原说话者真实意图。对于图像，执行详尽的视觉元素分析与高精度OCR，一字不差转录所有可见文本。对于音频，执行环境音分析与带智能纠错的语音转录。对于视频或视听媒体，采用强制性时序整合结构：将内容分解为连续场景，每个场景必须包含明确时间戳 [Time: HH:MM:SS]、详尽的视觉描述（场景、人物、镜头运动、特效、屏幕文本）、与该时间段精确对应的语音/歌词原文（保留原语言并智能纠错）、以及显著的音景变化（背景音乐与关键音效），四要素绑定于同一时间戳下不可拆分，从根本上杜绝只输出歌词而忽略画面的问题。"
# MediaInsertPrompt: 多模态数据插入到系统提示词的分隔提示
MediaInsertPrompt="服务器已处理多模态数据，Var工具箱已自动提取多模态数据信息，信息元如下——"
# MultiModalModelOutputMaxTokens: 多模态模型输出最大 token 数
MultiModalModelOutputMaxTokens=50000
# MultiModalModelContent: 多模态模型上下文最大 token 数
MultiModalModelContent=250000
# MultiModalModelThinkingBudget: 多模态模型思维预算 token 数
MultiModalModelThinkingBudget=23000
# MultiModalModelAsynchronousLimit: 多模态异步请求上限（最小 1，设 10 则每次最多异步 10 个图片）
MultiModalModelAsynchronousLimit=10
