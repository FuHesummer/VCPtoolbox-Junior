    { "path": "Agent",                  "type": "dir",  "sync": "merge" },
    { "path": "TVStxt",                 "type": "dir",  "sync": "merge" },
    { "path": "knowledge",              "type": "dir",  "sync": "merge" },
    { "path": "thinking",               "type": "dir",  "sync": "merge" },
    { "path": "dailynote",              "type": "dir" },
    { "path": "image",                  "type": "dir" },
    { "path": "VectorStore",            "type": "dir" },
    { "path": "DebugLog",               "type": "dir" },
    { "path": "VCPTimedContacts",       "type": "dir" },
    { "path": "VCPAsyncResults",        "type": "dir" },
    { "path": "agent_map.json",         "type": "file", "sync": "merge" },
    { "path": "ModelRedirect.json",     "type": "file" },
    { "path": "preprocessor_order.json","type": "file" },
    { "path": "ip_blacklist.json",      "type": "file" }
  ]
